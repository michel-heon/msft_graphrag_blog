        dct:modified     "2024-08-16T05:54:10.447Z"^^xsd:dateTime;
        dct:title        "Microsoft GraphRAG"@en, "Microsoft GraphRAG"@fr;
        <http://purl.org/ontology/bibo/status>
                <http://purl.org/spar/pso/draft>;
